# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...            # server-only, never exposed to client

# ---- Site ----
NEXT_PUBLIC_SITE_URL=https://studynook.app

# Google Maps + Places (client). Enable Maps JavaScript API + Places API.
# Powers the onboarding address picker and the search results map.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIza...

# ---- Payments (Razorpay) ----
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ---- Email (Resend) ----
RESEND_API_KEY=
EMAIL_FROM="StudyNook <hello@studynook.app>"

# ---- AI (optional; planner falls back to templates without it) ----
ANTHROPIC_API_KEY=

# ---- OAuth (configured in Supabase Auth dashboard; listed for reference) ----
# Google OAuth redirect: https://YOUR-PROJECT.supabase.co/auth/v1/callback

# Secret for authenticating Vercel Cron -> /api/cron/* endpoints
CRON_SECRET=
